{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "lib": ["esnext", "dom"],
    "types": [],
    "typeRoots": ["./node_modules/@types", "./"],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}
